generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                        String                            @id @default(cuid())
  name                      String?
  username                  String?                           @unique
  email                     String?                           @unique
  emailVerified             DateTime?
  image                     String?
  password                  String?
  role                      UserRole                          @default(USER)
  onboardingCompleted       Boolean                           @default(false)
  examCategory              ExamCategory?
  preparationLevel          PreparationLevel?
  dailyPracticeGoal         Int                               @default(20)
  recommendationEngine      Boolean                           @default(true)
  notificationPrefs         Json?
  accountState              AccountState                      @default(ACTIVE)
  flagged                   Boolean                           @default(false)
  moderatorStatus           ModeratorStatus                   @default(ACTIVE)
  createdAt                 DateTime                          @default(now())
  updatedAt                 DateTime                          @updatedAt
  accounts                  Account[]
  attempts                  Attempt[]
  auditLogs                 AuditLog[]                        @relation("AuditActor")
  targetedAudits            AuditLog[]                        @relation("AuditTarget")
  BackgroundJob             BackgroundJob[]
  badgeSnapshots            BadgeSnapshot[]
  certificateSnapshots      CertificateSnapshot[]
  createdChallenges         Challenge[]
  publishedChallenges       Challenge[]                       @relation("ChallengePublisher")
  reviewedChallenges        Challenge[]                       @relation("ChallengeReviewer")
  competitionAttempts       CompetitionAttempt[]
  CompetitionAudit          CompetitionAudit[]
  createdSchedules          CompetitionSchedule[]             @relation("ScheduleCreatedBy")
  competitionSessions       CompetitionSession[]
  publishedVersions         CompetitionVersion[]              @relation("CompetitionVersionPublisher")
  createdCompetitions       Competition[]                     @relation("CompetitionCreatedBy")
  updatedCompetitions       Competition[]                     @relation("CompetitionUpdatedBy")
  competitiveActivities     CompetitiveActivity[]
  deploymentAudits          DeploymentAudit[]                 @relation("DeploymentAuditActor")
  deploymentLocks           DeploymentLock[]                  @relation("DeploymentLockUser")
  createdFeatures           FeatureFlag[]                     @relation("FeatureCreatedBy")
  updatedFeatures           FeatureFlag[]                     @relation("FeatureUpdatedBy")
  ImportSession             ImportSession[]
  leaderboardEntries        LeaderboardEntry[]
  createdByNotes            ModerationNote[]                  @relation("ModerationNoteCreator")
  moderationNotes           ModerationNote[]                  @relation("ModerationNoteUser")
  createdByModNotes         ModeratorNote[]                   @relation("ModeratorNoteCreator")
  moderatorNotes            ModeratorNote[]                   @relation("ModeratorNoteModerator")
  operationalIssueAudits    OperationalIssueAudit[]           @relation("OperationalAuditActor")
  assignedIssues            OperationalIssue[]                @relation("IssueAssignedTo")
  dismissedIssues           OperationalIssue[]                @relation("IssueDismissedBy")
  paymentOrders             PaymentOrder[]
  acknowledgedAlerts        PlatformAlert[]                   @relation("AlertAcknowledger")
  ownedIncidents            PlatformIncident[]                @relation("IncidentOwner")
  monitoringAudits          PlatformMonitoringAudit[]         @relation("MonitoringAuditActor")
  updatedSettings           PlatformSetting[]                 @relation("SettingUpdater")
  initiatedDeployments      PublishDeployment[]               @relation("DeploymentInitiator")
  publishingLocks           PublishingLock[]                  @relation("PublishingLockUser")
  attemptLogs               QuestionAttemptLog[]
  QuestionAuditLog          QuestionAuditLog[]
  createdFlags              QuestionFlag[]                    @relation("QuestionFlagCreator")
  QuestionGovernanceAudit   QuestionGovernanceAudit[]
  dismissedRecommendations  QuestionRecommendationDismissal[]
  createdQuestions          Question[]
  rankingSnapshots          RankingSnapshot[]
  registrations             Registration[]
  reportNotes               ReportNote[]                      @relation("ReportNoteAuthor")
  submittedReports          Report[]                          @relation("ReportSubmitter")
  reviewedReports           Report[]                          @relation("ReportReviewer")
  targetedReports           Report[]                          @relation("ReportTarget")
  rewardLedgerEntries       RewardLedger[]
  roleChangesAsActor        RoleChangeAudit[]                 @relation("RoleChangeBy")
  roleChangesAsTarget       RoleChangeAudit[]                 @relation("RoleChangeTarget")
  savedFilters              SavedFilter[]
  searchAnalytics           SearchAnalytics[]
  sessions                  Session[]
  settingAudits             SettingAudit[]                    @relation("SettingAuditActor")
  tournamentLeaderboards    TournamentLeaderboard[]
  transactions              Transaction[]
  achievements              UserAchievement[]
  categoryPerformance       UserCategoryPerformance[]
  UserDifficultyPerformance UserDifficultyPerformance[]
  performanceProfile        UserPerformanceProfile?
  performanceSnapshot       UserPerformanceSnapshot?
  UserSubjectPerformance    UserSubjectPerformance[]
  subscriptions             UserSubscription[]
  VersionBuildAudit         VersionBuildAudit[]

  @@index([email])
  @@index([username])
  @@index([accountState])
  @@index([flagged])
  @@index([moderatorStatus])
  @@map("users")
}

model ModerationNote {
  id          String   @id @default(cuid())
  userId      String
  createdById String
  note        String
  createdAt   DateTime @default(now())
  createdBy   User     @relation("ModerationNoteCreator", fields: [createdById], references: [id], onDelete: Cascade)
  user        User     @relation("ModerationNoteUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdById])
  @@map("moderation_notes")
}

model ModeratorNote {
  id          String   @id @default(cuid())
  moderatorId String
  createdById String
  note        String
  createdAt   DateTime @default(now())
  createdBy   User     @relation("ModeratorNoteCreator", fields: [createdById], references: [id], onDelete: Cascade)
  moderator   User     @relation("ModeratorNoteModerator", fields: [moderatorId], references: [id], onDelete: Cascade)

  @@index([moderatorId])
  @@index([createdById])
  @@map("moderator_notes")
}

model RoleChangeAudit {
  id           String   @id @default(cuid())
  targetUserId String
  changedById  String
  previousRole UserRole
  newRole      UserRole
  reason       String?
  changedAt    DateTime @default(now())
  changedBy    User     @relation("RoleChangeBy", fields: [changedById], references: [id], onDelete: Cascade)
  targetUser   User     @relation("RoleChangeTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@index([targetUserId])
  @@index([changedById])
  @@index([changedAt])
  @@map("role_change_audit")
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  description String?
  category    String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  roles       RolePermission[]

  @@index([category])
  @@index([key])
  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(cuid())
  role         UserRole
  permissionId String
  createdAt    DateTime   @default(now())
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
  @@index([role])
  @@index([permissionId])
  @@map("role_permissions")
}

model AuditLog {
  id           String          @id @default(cuid())
  action       String
  entityType   AuditEntityType
  entityId     String?
  actorId      String?
  targetUserId String?
  metadata     Json?
  ipAddress    String?
  userAgent    String?
  severity     AuditSeverity   @default(LOW)
  createdAt    DateTime        @default(now())
  actor        User?           @relation("AuditActor", fields: [actorId], references: [id])
  targetUser   User?           @relation("AuditTarget", fields: [targetUserId], references: [id])

  @@index([actorId])
  @@index([targetUserId])
  @@index([entityType])
  @@index([entityType, entityId])
  @@index([severity])
  @@index([createdAt])
  @@map("audit_logs")
}

model SubscriptionPlan {
  id            String             @id @default(cuid())
  name          String
  slug          String             @unique
  description   String?
  price         Float
  duration      Int
  features      Json?
  isActive      Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  premiumAccess PremiumAccess[]
  subscriptions UserSubscription[]

  @@map("subscription_plans")
}

model UserSubscription {
  id               String             @id @default(cuid())
  userId           String
  planId           String
  status           SubscriptionStatus @default(PENDING)
  startsAt         DateTime           @default(now())
  expiresAt        DateTime?
  paymentProvider  PaymentProvider    @default(SYSTEM)
  paymentReference String?
  autoRenew        Boolean            @default(false)
  canceledAt       DateTime?
  plan             SubscriptionPlan   @relation(fields: [planId], references: [id], onDelete: Cascade)
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([planId])
  @@map("user_subscriptions")
}

model PremiumAccess {
  id             String             @id @default(cuid())
  challengeId    String             @unique
  requiredPlanId String?
  accessLevel    PremiumAccessLevel @default(FREE)
  challenge      Challenge          @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  requiredPlan   SubscriptionPlan?  @relation(fields: [requiredPlanId], references: [id])

  @@index([challengeId])
  @@index([requiredPlanId])
  @@map("premium_access")
}

model Transaction {
  id         String            @id @default(cuid())
  userId     String
  type       TransactionType
  amount     Float
  status     TransactionStatus @default(PENDING)
  provider   PaymentProvider   @default(SYSTEM)
  providerId String?
  metadata   Json?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("transactions")
}

model RevenueSnapshot {
  id                  String   @id @default(cuid())
  totalRevenue        Float
  monthlyRevenue      Float
  activeSubscriptions Int
  conversionRate      Float
  recordedAt          DateTime @default(now())

  @@index([recordedAt])
  @@map("revenue_snapshots")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@index([provider])
  @@index([providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Challenge {
  id                   String                      @id @default(cuid())
  title                String
  slug                 String                      @unique
  description          String?
  category             ExamCategory?
  difficulty           ChallengeDifficulty         @default(MEDIUM)
  durationInMinutes    Int
  totalQuestions       Int                         @default(0)
  visibility           ChallengeVisibility         @default(PUBLIC)
  participationType    ParticipationType           @default(OPEN)
  status               ChallengeStatus             @default(DRAFT)
  leaderboardFrozen    Boolean                     @default(false)
  scheduledAt          DateTime?
  startsAt             DateTime?
  endsAt               DateTime?
  createdById          String?
  reviewedById         String?
  publishedById        String?
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt
  attempts             Attempt[]
  invites              ChallengeInvite[]
  snapshots            ChallengeQuestionSnapshot[]
  questions            ChallengeQuestion[]
  createdBy            User?                       @relation(fields: [createdById], references: [id])
  publishedBy          User?                       @relation("ChallengePublisher", fields: [publishedById], references: [id])
  reviewedBy           User?                       @relation("ChallengeReviewer", fields: [reviewedById], references: [id])
  leaderboard          LeaderboardEntry[]
  premiumAccess        PremiumAccess?
  reports              Report[]                    @relation("ReportedChallenge")
  tournamentChallenges TournamentChallenge[]

  @@index([slug])
  @@index([category])
  @@index([status])
  @@index([difficulty])
  @@index([scheduledAt])
  @@index([startsAt])
  @@index([endsAt])
  @@index([createdById])
  @@index([reviewedById])
  @@index([publishedById])
  @@index([createdAt])
  @@map("challenges")
}

model QuestionAuditLog {
  id              String              @id @default(cuid())
  questionId      String
  actorId         String
  action          QuestionAuditAction
  previousStatus  RevisionStatus?
  nextStatus      RevisionStatus?
  previousVersion Int?
  nextVersion     Int?
  reason          String?
  metadata        Json?
  createdAt       DateTime            @default(now())
  actor           User                @relation(fields: [actorId], references: [id])
  question        Question            @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@index([actorId])
  @@index([action])
  @@index([createdAt])
  @@index([questionId, action, createdAt(sort: Desc)])
  @@map("question_audit_logs")
}

model QuestionGovernanceAudit {
  id            String          @id @default(cuid())
  questionId    String
  action        String
  reason        String?
  adminId       String?
  triggerSource TriggerSource
  previousState LifecycleState?
  newState      LifecycleState
  timestamp     DateTime        @default(now())
  admin         User?           @relation(fields: [adminId], references: [id])
  question      Question        @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@index([adminId])
  @@index([timestamp])
  @@map("question_governance_audits")
}

model QuestionCodeCounter {
  id       String @id @default(cuid())
  category String @unique
  counter  Int    @default(0)

  @@map("question_code_counters")
}

model BackgroundJob {
  id             String    @id @default(cuid())
  type           JobType
  status         JobStatus @default(QUEUED)
  stage          JobStage  @default(PARSING)
  priority       Int       @default(0)
  progress       Int       @default(0)
  createdById    String
  organizationId String?
  startedAt      DateTime?
  completedAt    DateTime?
  failedAt       DateTime?
  cancelledAt    DateTime?
  retryCount     Int       @default(0)
  maxRetries     Int       @default(3)
  payloadJson    Json?
  resultJson     Json?
  errorMessage   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdBy      User      @relation(fields: [createdById], references: [id])

  @@index([status])
  @@index([type])
  @@index([createdById])
  @@map("background_jobs")
}

model ImportSession {
  id               String                     @id @default(cuid())
  jobId            String?                    @unique
  organizationId   String?
  createdById      String
  sourceType       ImportSourceType
  originalFile     String?
  conflictStrategy ConflictResolutionStrategy @default(SKIP)
  totalRows        Int                        @default(0)
  validRows        Int                        @default(0)
  invalidRows      Int                        @default(0)
  warningsCount    Int                        @default(0)
  duplicatesCount  Int                        @default(0)
  importedCount    Int                        @default(0)
  skippedCount     Int                        @default(0)
  failedCount      Int                        @default(0)
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
  results          ImportResult[]
  rows             ImportRow[]
  createdBy        User                       @relation(fields: [createdById], references: [id])

  @@index([createdById])
  @@map("import_sessions")
}

model ImportRow {
  id                 String          @id @default(cuid())
  sessionId          String
  rowNumber          Int
  status             ImportRowStatus @default(PENDING)
  rawPayload         Json
  normalizedPayload  Json?
  validationErrors   Json?
  validationWarnings Json?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  session            ImportSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([status])
  @@map("import_rows")
}

model ImportResult {
  id            String        @id @default(cuid())
  sessionId     String
  questionId    String?
  wasSuccessful Boolean
  errorMessage  String?
  createdAt     DateTime      @default(now())
  session       ImportSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("import_results")
}

model ImportFingerprint {
  id            String   @id @default(cuid())
  checksum      String   @unique
  hashAlgorithm String
  uploadedById  String
  uploadedAt    DateTime @default(now())
  fileSize      Int
  recordCount   Int

  @@index([checksum])
  @@map("import_fingerprints")
}

model ChallengeQuestion {
  id          String    @id @default(cuid())
  challengeId String
  questionId  String
  orderIndex  Int
  marks       Int       @default(1)
  isMandatory Boolean   @default(true)
  createdAt   DateTime  @default(now())
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  question    Question  @relation(fields: [questionId], references: [id])

  @@unique([challengeId, questionId])
  @@index([challengeId])
  @@index([questionId])
  @@map("challenge_questions")
}

model ChallengeQuestionSnapshot {
  id                 String              @id @default(cuid())
  challengeId        String
  originalQuestionId String
  questionVersion    Int
  questionCode       String
  question           String
  options            Json
  correctOption      String
  explanation        String?
  category           String
  subject            String
  difficulty         ChallengeDifficulty
  tags               String[]
  language           String
  orderIndex         Int
  createdAt          DateTime            @default(now())
  challenge          Challenge           @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@index([challengeId])
  @@index([originalQuestionId])
  @@map("challenge_question_snapshots")
}

model Attempt {
  id                 String            @id @default(cuid())
  userId             String
  challengeId        String
  status             AttemptStatus     @default(IN_PROGRESS)
  score              Int               @default(0)
  correctAnswers     Int               @default(0)
  wrongAnswers       Int               @default(0)
  unansweredCount    Int               @default(0)
  totalAnswered      Int               @default(0)
  startedAt          DateTime          @default(now())
  submittedAt        DateTime?
  expiresAt          DateTime?
  timeTakenInSeconds Int?
  isAutoSubmitted    Boolean           @default(false)
  questionOrder      Json?
  optionOrders       Json?
  isFlagged          Boolean           @default(false)
  tabSwitchCount     Int               @default(0)
  blurCount          Int               @default(0)
  totalViolations    Int               @default(0)
  tournamentId       String?
  antiCheatLogs      AntiCheatLog[]
  answers            AttemptAnswer[]
  challenge          Challenge         @relation(fields: [challengeId], references: [id])
  tournament         Tournament?       @relation(fields: [tournamentId], references: [id])
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  leaderboardEntry   LeaderboardEntry?

  @@unique([userId, challengeId])
  @@index([userId])
  @@index([challengeId])
  @@index([status])
  @@index([submittedAt])
  @@index([isFlagged])
  @@index([userId, status])
  @@index([challengeId, status])
  @@map("attempts")
}

model AttemptAnswer {
  id                 String    @id @default(cuid())
  attemptId          String
  questionId         String
  selectedOption     String?
  selectedOptionId   String?
  isCorrect          Boolean?
  isSkipped          Boolean   @default(false)
  timeSpentInSeconds Int?
  answeredAt         DateTime? @default(now())
  attempt            Attempt   @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@index([questionId])
  @@map("attempt_answers")
}

model LeaderboardEntry {
  id                 String    @id @default(cuid())
  challengeId        String
  userId             String
  attemptId          String    @unique
  rank               Int
  score              Int
  accuracy           Float
  timeTakenInSeconds Int
  correctAnswers     Int       @default(0)
  totalQuestions     Int       @default(0)
  category           String?
  submittedAt        DateTime?
  frozenAt           DateTime  @default(now())
  attempt            Attempt   @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  challenge          Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([challengeId, userId])
  @@index([challengeId, rank])
  @@index([category, score])
  @@index([category, rank])
  @@index([userId])
  @@index([challengeId])
  @@index([challengeId, score(sort: Desc)])
  @@map("leaderboard_entries")
}

model LeaderboardProjection {
  leaderboardKey   String   @id
  participantCount Int      @default(0)
  highestScore     Int      @default(0)
  averageScore     Float    @default(0)
  averageAccuracy  Float    @default(0)
  top3Snapshot     Json?
  lastUpdated      DateTime @updatedAt
  currentVersion   String   @default("1.0")

  @@map("leaderboard_projections")
}

model RankingSnapshot {
  id                String   @id @default(cuid())
  leaderboardKey    String
  userId            String
  rank              Int
  score             Int
  accuracy          Float
  completionTime    Int
  percentile        Float
  snapshotTimestamp DateTime @default(now())
  rankingVersion    String   @default("1.0")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([leaderboardKey, userId])
  @@index([leaderboardKey, rank])
  @@index([userId])
  @@map("ranking_snapshots")
}

model RewardLedger {
  id            String   @id @default(cuid())
  rewardEvent   String
  rewardType    String
  issuer        String   @default("SYSTEM")
  recipientId   String
  referenceId   String?
  pipelineStage String
  status        String
  failureReason String?
  retryCount    Int      @default(0)
  issuedAt      DateTime @default(now())
  user          User     @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId])
  @@map("reward_ledger")
}

model CertificateSnapshot {
  id                 String   @id @default(cuid())
  verificationToken  String   @unique
  participantName    String
  competitionName    String
  competitionVersion String
  certificateType    String
  rank               Int?
  score              Int?
  completionDate     DateTime
  issueDate          DateTime @default(now())
  certificateVersion String   @default("1.0")
  issuer             String   @default("QuizArena")
  qrPayload          String
  brandAssetsVersion String
  pdfUrl             String?
  userId             String
  competitionId      String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, competitionId, certificateType])
  @@map("certificate_snapshots")
}

model BadgeSnapshot {
  id            String   @id @default(cuid())
  badgeType     String
  userId        String
  competitionId String?
  issuedAt      DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeType, competitionId])
  @@map("badge_snapshots")
}

model ChallengeInvite {
  id            String       @id @default(cuid())
  challengeId   String
  email         String
  invitedUserId String?
  status        InviteStatus @default(PENDING)
  inviteCode    String       @unique @default(cuid())
  createdAt     DateTime     @default(now())
  expiresAt     DateTime?
  acceptedAt    DateTime?
  challenge     Challenge    @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([challengeId, email])
  @@index([challengeId])
  @@index([email])
  @@index([inviteCode])
  @@index([status])
  @@map("challenge_invites")
}

model AntiCheatLog {
  id            String        @id @default(cuid())
  attemptId     String
  violationType ViolationType
  count         Int           @default(1)
  metadata      Json?
  reportedAt    DateTime      @default(now())
  attempt       Attempt       @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@unique([attemptId, violationType])
  @@index([attemptId])
  @@map("anti_cheat_logs")
}

model QuestionAnalytics {
  id                  String    @id @default(cuid())
  questionId          String    @unique
  totalAttempts       Int       @default(0)
  correctAttempts     Int       @default(0)
  incorrectAttempts   Int       @default(0)
  averageResponseTime Float     @default(0)
  accuracyRate        Float     @default(0)
  usageCount          Int       @default(0)
  flaggedCount        Int       @default(0)
  lastUsedAt          DateTime?
  updatedAt           DateTime  @updatedAt
  question            Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([accuracyRate])
  @@index([usageCount])
  @@map("question_analytics")
}

model ChallengeAnalytics {
  id                String   @id @default(cuid())
  challengeId       String   @unique
  totalAttempts     Int      @default(0)
  completedAttempts Int      @default(0)
  totalScore        Float    @default(0)
  averageScore      Float    @default(0)
  highestScore      Int      @default(0)
  lowestScore       Int      @default(0)
  averageTimeSpent  Float    @default(0)
  averageAccuracy   Float    @default(0)
  completionRate    Float    @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([challengeId])
  @@map("challenge_analytics")
}

model DailyAnalytics {
  id                String   @id @default(cuid())
  date              DateTime @unique @db.Date
  totalAttempts     Int      @default(0)
  completedAttempts Int      @default(0)
  totalScore        Float    @default(0)
  averageScore      Float    @default(0)
  averageAccuracy   Float    @default(0)
  newUsers          Int      @default(0)
  activeUsers       Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([date])
  @@map("daily_analytics")
}

model Report {
  id                String         @id @default(cuid())
  type              ReportType
  reason            String
  description       String?
  status            ReportStatus   @default(OPEN)
  priority          ReportPriority @default(MEDIUM)
  reportedById      String
  targetUserId      String?
  targetChallengeId String?
  targetQuestionId  String?
  reviewedById      String?
  reviewedAt        DateTime?
  resolutionNotes   String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  notes             ReportNote[]
  reportedBy        User           @relation("ReportSubmitter", fields: [reportedById], references: [id], onDelete: Cascade)
  reviewedBy        User?          @relation("ReportReviewer", fields: [reviewedById], references: [id])
  targetChallenge   Challenge?     @relation("ReportedChallenge", fields: [targetChallengeId], references: [id])
  targetQuestion    Question?      @relation("ReportedQuestion", fields: [targetQuestionId], references: [id])
  targetUser        User?          @relation("ReportTarget", fields: [targetUserId], references: [id])

  @@index([status])
  @@index([priority])
  @@index([type])
  @@index([reportedById])
  @@index([targetUserId])
  @@index([targetChallengeId])
  @@index([targetQuestionId])
  @@index([reviewedById])
  @@index([createdAt])
  @@map("reports")
}

model ReportNote {
  id         String   @id @default(cuid())
  reportId   String
  authorId   String
  content    String
  isInternal Boolean  @default(true)
  createdAt  DateTime @default(now())
  author     User     @relation("ReportNoteAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  report     Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([authorId])
  @@map("report_notes")
}

model PlatformSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  category    String
  description String?
  isProtected Boolean  @default(false)
  updatedById String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
  updatedBy   User?    @relation("SettingUpdater", fields: [updatedById], references: [id])

  @@index([category])
  @@index([key])
  @@map("platform_settings")
}

model SettingAudit {
  id            String   @id @default(cuid())
  settingKey    String
  previousValue Json?
  newValue      Json
  reason        String?
  changedById   String
  changedAt     DateTime @default(now())
  changedBy     User     @relation("SettingAuditActor", fields: [changedById], references: [id])

  @@index([settingKey])
  @@index([changedById])
  @@index([changedAt])
  @@map("setting_audits")
}

model FeatureFlag {
  id           String      @id @default(cuid())
  key          String      @unique
  name         String
  description  String?
  enabled      Boolean     @default(false)
  rolloutType  RolloutType
  rolloutValue Int?
  environments Json?
  createdById  String?
  updatedById  String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  createdBy    User?       @relation("FeatureCreatedBy", fields: [createdById], references: [id])
  updatedBy    User?       @relation("FeatureUpdatedBy", fields: [updatedById], references: [id])

  @@index([key])
  @@index([enabled])
  @@map("feature_flags")
}

model UserPerformanceProfile {
  id                     String    @id @default(cuid())
  userId                 String    @unique
  currentStreak          Int       @default(0)
  longestStreak          Int       @default(0)
  lastParticipationAt    DateTime?
  participationGaps      Int       @default(0)
  disciplineIndex        Float     @default(100.0)
  totalAttempts          Int       @default(0)
  completedAttempts      Int       @default(0)
  averageScore           Float     @default(0)
  averageAccuracy        Float     @default(0)
  totalCorrect           Int       @default(0)
  totalAnswered          Int       @default(0)
  strongestCategory      String?
  weakestCategory        String?
  readinessScore         Float     @default(0)
  lastInsightGeneratedAt DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_performance_profiles")
}

model UserCategoryPerformance {
  id              String    @id @default(cuid())
  userId          String
  category        String
  totalAttempts   Int       @default(0)
  averageScore    Float     @default(0)
  averageAccuracy Float     @default(0)
  totalCorrect    Int       @default(0)
  totalAnswered   Int       @default(0)
  lastAttemptAt   DateTime?
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
  @@index([userId])
  @@index([category])
  @@map("user_category_performance")
}

model UserDifficultyPerformance {
  id              String              @id @default(cuid())
  userId          String
  difficulty      ChallengeDifficulty
  totalAttempts   Int                 @default(0)
  averageScore    Float               @default(0)
  averageAccuracy Float               @default(0)
  totalCorrect    Int                 @default(0)
  totalAnswered   Int                 @default(0)
  lastAttemptAt   DateTime?
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, difficulty])
  @@index([userId])
  @@index([difficulty])
  @@map("user_difficulty_performance")
}

model UserSubjectPerformance {
  id              String    @id @default(cuid())
  userId          String
  subject         String
  totalAttempts   Int       @default(0)
  averageScore    Float     @default(0)
  averageAccuracy Float     @default(0)
  totalCorrect    Int       @default(0)
  totalAnswered   Int       @default(0)
  lastAttemptAt   DateTime?
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, subject])
  @@index([userId])
  @@index([subject])
  @@map("user_subject_performance")
}

model CompetitiveActivity {
  id        String       @id @default(cuid())
  userId    String
  type      ActivityType
  content   String
  metadata  Json?
  createdAt DateTime     @default(now())
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("competitive_activities")
}

model UserAchievement {
  id         String          @id @default(cuid())
  userId     String
  type       AchievementType
  unlockedAt DateTime        @default(now())
  metadata   Json?
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId])
  @@map("user_achievements")
}

model Season {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  description String?
  startsAt    DateTime
  endsAt      DateTime
  status      SeasonStatus  @default(UPCOMING)
  category    ExamCategory?
  bannerImage String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  tournaments Tournament[]

  @@index([slug])
  @@index([status])
  @@index([startsAt])
  @@index([endsAt])
  @@map("seasons")
}

model Tournament {
  id                String                  @id @default(cuid())
  seasonId          String
  title             String
  description       String?
  startsAt          DateTime
  endsAt            DateTime
  visibility        ChallengeVisibility     @default(PUBLIC)
  participationType ParticipationType       @default(OPEN)
  status            TournamentStatus        @default(UPCOMING)
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  attempts          Attempt[]
  challenges        TournamentChallenge[]
  leaderboard       TournamentLeaderboard[]
  season            Season                  @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@index([seasonId])
  @@index([status])
  @@map("tournaments")
}

model TournamentChallenge {
  id           String     @id @default(cuid())
  tournamentId String
  challengeId  String
  order        Int        @default(0)
  challenge    Challenge  @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, challengeId])
  @@index([tournamentId])
  @@index([challengeId])
  @@map("tournament_challenges")
}

model TournamentLeaderboard {
  id                       String     @id @default(cuid())
  userId                   String
  tournamentId             String
  totalScore               Int        @default(0)
  averageAccuracy          Float      @default(0)
  totalChallengesCompleted Int        @default(0)
  rank                     Int        @default(0)
  updatedAt                DateTime   @updatedAt
  tournament               Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user                     User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tournamentId])
  @@index([tournamentId, rank])
  @@index([userId])
  @@map("tournament_leaderboards")
}

model SavedFilter {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  filters     Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("saved_filters")
}

model SearchAnalytics {
  id          String   @id @default(cuid())
  userId      String?
  query       String?
  filters     Json?
  resultCount Int
  latencyMs   Int
  createdAt   DateTime @default(now())
  user        User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@map("search_analytics")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  tokenHash String   @unique
  expires   DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([tokenHash])
  @@map("password_reset_tokens")
}

model UserPerformanceSnapshot {
  id                 String   @id @default(cuid())
  userId             String   @unique
  overallAccuracy    Float    @default(0)
  currentRank        Int?
  percentile         Int      @default(0)
  currentStreak      Int      @default(0)
  highestStreak      Int      @default(0)
  bestCategory       String?
  weakestCategory    String?
  totalAttempts      Int      @default(0)
  competitionsPlayed Int      @default(0)
  lastUpdatedAt      DateTime @default(now())
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([currentRank])
  @@map("user_performance_snapshots")
}

model LeaderboardSnapshot {
  id                     String   @id @default(cuid())
  totalParticipants      Int      @default(0)
  activeCompetitions     Int      @default(0)
  rankingMetadata        Json?
  cachedLeaderboardStats Json?
  lastUpdatedAt          DateTime @default(now())

  @@map("leaderboard_snapshots")
}

model QuestionUsageStats {
  id                String               @id @default(cuid())
  questionId        String               @unique
  timesServed       Int                  @default(0)
  timesAttempted    Int                  @default(0)
  correctAttempts   Int                  @default(0)
  incorrectAttempts Int                  @default(0)
  skippedAttempts   Int                  @default(0)
  averageTimeSpent  Float                @default(0)
  actualDifficulty  ChallengeDifficulty?
  successRate       Float                @default(0)
  medianTimeSpent   Float                @default(0)
  fastestTime       Int?
  slowestTime       Int?
  p90Time           Int?
  reportCount       Int                  @default(0)
  successRateTrend  String               @default("STABLE")
  attemptsTrend     String               @default("STABLE")
  reportsTrend      String               @default("STABLE")
  lastAttemptedAt   DateTime?
  lastServedAt      DateTime?
  analyticsVersion  Int                  @default(1)
  dataQuality       DataQuality          @default(INSUFFICIENT)
  lastCalculatedAt  DateTime?
  needsProcessing   Boolean              @default(false)
  updatedAt         DateTime             @updatedAt
  question          Question             @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([needsProcessing])
  @@index([actualDifficulty])
  @@index([successRate])
  @@index([dataQuality])
  @@index([timesAttempted])
  @@map("question_usage_stats")
}

model QuestionAttemptLog {
  id             String   @id @default(cuid())
  userId         String
  questionId     String
  challengeId    String?
  duration       Int
  answerSelected String?
  isCorrect      Boolean?
  isSkipped      Boolean  @default(false)
  isTimeout      Boolean  @default(false)
  createdAt      DateTime @default(now())
  question       Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@index([createdAt])
  @@map("question_attempt_logs")
}

model QuestionFlag {
  id          String           @id @default(cuid())
  questionId  String
  flagType    QuestionFlagType
  reason      String?
  createdById String?
  createdAt   DateTime         @default(now())
  createdBy   User?            @relation("QuestionFlagCreator", fields: [createdById], references: [id])
  question    Question         @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, flagType])
  @@index([questionId])
  @@index([flagType])
  @@map("question_flags")
}

model QuestionRecommendationDismissal {
  id                 String   @id @default(cuid())
  questionId         String
  recommendationType String
  dismissedById      String
  createdAt          DateTime @default(now())
  dismissedBy        User     @relation(fields: [dismissedById], references: [id], onDelete: Cascade)
  question           Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, recommendationType])
  @@map("question_recommendation_dismissals")
}

model AnalyticsJob {
  id            String             @id @default(cuid())
  jobType       String
  status        AnalyticsJobStatus
  startedAt     DateTime           @default(now())
  completedAt   DateTime?
  durationMs    Int?
  rowsProcessed Int                @default(0)
  errorMessage  String?
  metadata      Json?

  @@index([jobType])
  @@index([status])
  @@index([startedAt])
  @@map("analytics_jobs")
}

model OperationalRule {
  id          String                   @id @default(cuid())
  ruleKey     String                   @unique
  enabled     Boolean                  @default(true)
  severity    OperationalIssueSeverity
  threshold   Float
  description String?

  @@map("operational_rules")
}

model OperationalIssue {
  id               String                    @id @default(cuid())
  issueFingerprint String                    @unique
  questionId       String
  issueType        String
  severity         OperationalIssueSeverity
  previousSeverity OperationalIssueSeverity?
  status           OperationalIssueStatus    @default(OPEN)
  priority         OperationalIssueSeverity  @default(LOW)
  detectedAt       DateTime                  @default(now())
  lastEvaluatedAt  DateTime                  @default(now())
  resolvedAt       DateTime?
  dismissedById    String?
  dismissedAt      DateTime?
  assignedToId     String?
  dueDate          DateTime?
  resolutionNotes  String?
  audits           OperationalIssueAudit[]
  assignedTo       User?                     @relation("IssueAssignedTo", fields: [assignedToId], references: [id])
  dismissedBy      User?                     @relation("IssueDismissedBy", fields: [dismissedById], references: [id])
  question         Question                  @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@index([issueType])
  @@index([status])
  @@index([severity])
  @@index([priority])
  @@index([assignedToId])
  @@map("operational_issues")
}

model OperationalIssueAudit {
  id        String                 @id @default(cuid())
  issueId   String
  action    OperationalAuditAction
  actorId   String?
  reason    String?
  createdAt DateTime               @default(now())
  actor     User?                  @relation("OperationalAuditActor", fields: [actorId], references: [id])
  issue     OperationalIssue       @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@index([issueId])
  @@index([actorId])
  @@index([action])
  @@map("operational_issue_audits")
}

model Competition {
  id                      String                       @id @default(cuid())
  title                   String
  slug                    String                       @unique
  description             String?
  competitionType         CompetitionType
  status                  CompetitionStatus            @default(INACTIVE)
  lifecycleState          CompetitionLifecycle         @default(DRAFT)
  readinessScore          Int                          @default(0)
  healthStatus            CompetitionHealthStatus      @default(HEALTHY)
  visibility              CompetitionVisibility        @default(PUBLIC)
  exam                    ExamCategory?
  difficulty              ChallengeDifficulty          @default(MEDIUM)
  language                String                       @default("en")
  durationMinutes         Int
  totalQuestions          Int                          @default(0)
  maximumMarks            Int                          @default(0)
  version                 Int                          @default(1)
  lifecycleVersion        Int                          @default(1)
  isLatestVersion         Boolean                      @default(true)
  clonedFromCompetitionId String?
  startsAt                DateTime?
  endsAt                  DateTime?
  scheduledStart          DateTime?
  scheduledEnd            DateTime?
  publishedAt             DateTime?
  scheduledPublishAt      DateTime?
  scheduledExpiryAt       DateTime?
  activatedAt             DateTime?
  completedAt             DateTime?
  expiredAt               DateTime?
  archivedAt              DateTime?
  cancelledAt             DateTime?
  lastLifecycleUpdate     DateTime?
  lastLifecycleActor      String?
  createdById             String?
  updatedById             String?
  createdAt               DateTime                     @default(now())
  updatedAt               DateTime                     @updatedAt
  attempts                CompetitionAttempt[]
  auditTrail              CompetitionAudit[]
  config                  CompetitionConfig?
  economics               CompetitionEconomics?
  eligibility             CompetitionEligibility?
  lifecycleAudits         CompetitionLifecycleAudit[]
  pricingPolicies         CompetitionPricingPolicy[]
  questions               CompetitionQuestion[]
  schedule                CompetitionSchedule?
  sections                CompetitionSection[]
  sessions                CompetitionSession[]
  versions                CompetitionVersion[]
  clonedFrom              Competition?                 @relation("CompetitionClones", fields: [clonedFromCompetitionId], references: [id])
  clones                  Competition[]                @relation("CompetitionClones")
  createdBy               User?                        @relation("CompetitionCreatedBy", fields: [createdById], references: [id])
  updatedBy               User?                        @relation("CompetitionUpdatedBy", fields: [updatedById], references: [id])
  coupons                 Coupon[]
  deploymentLocks         DeploymentLock?
  paymentOrders           PaymentOrder[]
  alerts                  PlatformAlert[]
  incidents               PlatformIncident[]
  monitoringSnapshots     PlatformMonitoringSnapshot[]
  operationalMetrics      PlatformOperationalMetric[]
  publishingLock          PublishingLock?
  registrations           Registration[]

  @@index([slug])
  @@index([competitionType])
  @@index([status])
  @@index([visibility])
  @@index([exam])
  @@index([difficulty])
  @@index([startsAt])
  @@index([endsAt])
  @@index([createdById])
  @@index([createdAt])
  @@index([status, competitionType])
  @@index([status, visibility])
  @@index([isLatestVersion])
  @@index([clonedFromCompetitionId])
  @@map("competitions")
}

model CompetitionConfig {
  id                      String      @id @default(cuid())
  competitionId           String      @unique
  rules                   Json?
  rulesVersion            Int         @default(1)
  negativeMarkingEnabled  Boolean     @default(false)
  negativeMarkPerQuestion Float       @default(0)
  passingMarks            Int?
  allowRetake             Boolean     @default(false)
  randomizeQuestions      Boolean     @default(false)
  randomizeOptions        Boolean     @default(false)
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
  competition             Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)

  @@index([competitionId])
  @@map("competition_configs")
}

model CompetitionEconomics {
  id            String      @id @default(cuid())
  competitionId String      @unique
  entryFee      Float       @default(0)
  rewardPool    Float       @default(0)
  currency      String      @default("INR")
  metadata      Json?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)

  @@index([competitionId])
  @@map("competition_economics")
}

model CompetitionEligibility {
  id                 String      @id @default(cuid())
  competitionId      String      @unique
  criteria           Json?
  eligibilityVersion Int         @default(1)
  maxParticipants    Int?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  competition        Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)

  @@index([competitionId])
  @@map("competition_eligibility")
}

model CompetitionSection {
  id              String                @id @default(cuid())
  competitionId   String
  title           String
  slug            String
  description     String?
  instructions    String?
  displayOrder    Int                   @default(0)
  durationMinutes Int?
  totalQuestions  Int                   @default(0)
  maximumMarks    Int                   @default(0)
  passingMarks    Int?
  isMandatory     Boolean               @default(true)
  allowNavigation Boolean               @default(true)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  questions       CompetitionQuestion[]
  competition     Competition           @relation(fields: [competitionId], references: [id], onDelete: Cascade)

  @@unique([competitionId, slug])
  @@index([competitionId])
  @@index([displayOrder])
  @@map("competition_sections")
}

model CompetitionQuestion {
  id                 String               @id @default(cuid())
  competitionId      String
  questionId         String
  sectionId          String?
  displayOrder       Int                  @default(0)
  sectionOrder       Int                  @default(0)
  marks              Int                  @default(1)
  negativeMarks      Float                @default(0)
  questionWeight     Float                @default(1.0)
  difficultyOverride ChallengeDifficulty?
  timeLimitOverride  Int?
  isOptional         Boolean              @default(false)
  isBonus            Boolean              @default(false)
  isMandatory        Boolean              @default(true)
  createdAt          DateTime             @default(now())
  competition        Competition          @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  question           Question             @relation(fields: [questionId], references: [id])
  section            CompetitionSection?  @relation(fields: [sectionId], references: [id])

  @@unique([competitionId, questionId])
  @@index([competitionId])
  @@index([questionId])
  @@index([sectionId])
  @@index([displayOrder])
  @@map("competition_questions")
}

model CompetitionAudit {
  id            String                 @id @default(cuid())
  competitionId String
  action        CompetitionAuditAction
  actorId       String?
  previousState CompetitionStatus?
  newState      CompetitionStatus?
  reason        String?
  metadata      Json?
  createdAt     DateTime               @default(now())
  actor         User?                  @relation(fields: [actorId], references: [id])
  competition   Competition            @relation(fields: [competitionId], references: [id], onDelete: Cascade)

  @@index([competitionId])
  @@index([actorId])
  @@index([action])
  @@index([createdAt])
  @@index([competitionId, createdAt(sort: Desc)])
  @@map("competition_audits")
}

model CompetitionLifecycleAudit {
  id              String                @id @default(cuid())
  competitionId   String
  previousState   CompetitionLifecycle?
  newState        CompetitionLifecycle
  reason          String?
  performedBy     String?
  performedByType LifecycleActorType
  metadata        Json?
  createdAt       DateTime              @default(now())
  competition     Competition           @relation(fields: [competitionId], references: [id], onDelete: Cascade)

  @@index([competitionId])
  @@index([createdAt])
  @@index([newState])
  @@map("competition_lifecycle_audits")
}

model BulkOperationJob {
  id             String        @id @default(cuid())
  operationType  String
  status         BulkJobStatus @default(PENDING)
  totalItems     Int
  processedItems Int           @default(0)
  failedItems    Int           @default(0)
  results        Json?
  startedBy      String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  completedAt    DateTime?

  @@index([status])
  @@index([createdAt])
  @@map("bulk_operation_jobs")
}

model CompetitionVersion {
  id                  String                      @id @default(cuid())
  competitionId       String
  version             Int
  semanticVersion     String
  schemaVersion       Int                         @default(1)
  competitionSnapshot Json
  sectionsSnapshot    Json
  questionsSnapshot   Json
  rulesSnapshot       Json
  configSnapshot      Json
  snapshotHash        String
  manifestHash        String
  artifactHash        String
  fingerprint         String
  freezeDurationMs    Int?
  buildStartedAt      DateTime?
  buildCompletedAt    DateTime?
  buildNumber         Int?
  artifactSizeBytes   Int?
  manifestVersion     String?
  reason              String?
  artifactStatus      ArtifactStatus              @default(BUILDING)
  changelog           String?
  publishedAt         DateTime?
  publishedById       String?
  isActive            Boolean                     @default(false)
  createdAt           DateTime                    @default(now())
  parentVersionId     String?
  readinessSnapshotId String?
