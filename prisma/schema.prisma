generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                        String                            @id @default(cuid())
  name                      String?
  username                  String?                           @unique
  email                     String?                           @unique
  emailVerified             DateTime?
  image                     String?
  password                  String?
  role                      UserRole                          @default(USER)
  onboardingCompleted       Boolean                           @default(false)
  examCategory              ExamCategory?
  preparationLevel          PreparationLevel?
  dailyPracticeGoal         Int                               @default(20)
  recommendationEngine      Boolean                           @default(true)
  notificationPrefs         Json?
  accountState              AccountState                      @default(ACTIVE)
  flagged                   Boolean                           @default(false)
  moderatorStatus           ModeratorStatus                   @default(ACTIVE)
  createdAt                 DateTime                          @default(now())
  updatedAt                 DateTime                          @updatedAt
  accounts                  Account[]
  sessions                  Session[]
  attempts                  Attempt[]
  createdChallenges         Challenge[]
  reviewedChallenges        Challenge[]                       @relation("ChallengeReviewer")
  publishedChallenges       Challenge[]                       @relation("ChallengePublisher")
  createdQuestions          Question[]
  reviewedQuestions         Question[]                        @relation("QuestionReviewer")
  approvedQuestions         Question[]                        @relation("QuestionApprovedBy")
  moderationNotes           ModerationNote[]                  @relation("ModerationNoteUser")
  createdByNotes            ModerationNote[]                  @relation("ModerationNoteCreator")
  moderatorNotes            ModeratorNote[]                   @relation("ModeratorNoteModerator")
  createdByModNotes         ModeratorNote[]                   @relation("ModeratorNoteCreator")
  roleChangesAsTarget       RoleChangeAudit[]                 @relation("RoleChangeTarget")
  roleChangesAsActor        RoleChangeAudit[]                 @relation("RoleChangeBy")
  submittedReports          Report[]                          @relation("ReportSubmitter")
  targetedReports           Report[]                          @relation("ReportTarget")
  reviewedReports           Report[]                          @relation("ReportReviewer")
  reportNotes               ReportNote[]                      @relation("ReportNoteAuthor")
  updatedSettings           PlatformSetting[]                 @relation("SettingUpdater")
  settingAudits             SettingAudit[]                    @relation("SettingAuditActor")
  auditLogs                 AuditLog[]                        @relation("AuditActor")
  targetedAudits            AuditLog[]                        @relation("AuditTarget")
  rankingSnapshots          RankingSnapshot[]
  rewardLedgerEntries       RewardLedger[]
  certificateSnapshots      CertificateSnapshot[]
  badgeSnapshots            BadgeSnapshot[]

  subscriptions             UserSubscription[]
  transactions              Transaction[]
  createdFeatures           FeatureFlag[]                     @relation("FeatureCreatedBy")
  updatedFeatures           FeatureFlag[]                     @relation("FeatureUpdatedBy")
  leaderboardEntries        LeaderboardEntry[]
  performanceProfile        UserPerformanceProfile?
  categoryPerformance       UserCategoryPerformance[]
  competitiveActivities     CompetitiveActivity[]
  achievements              UserAchievement[]
  tournamentLeaderboards    TournamentLeaderboard[]
  UserDifficultyPerformance UserDifficultyPerformance[]
  UserSubjectPerformance    UserSubjectPerformance[]
  QuestionImportJob         QuestionImportJob[]
  savedFilters              SavedFilter[]
  searchAnalytics           SearchAnalytics[]
  QuestionAuditLog          QuestionAuditLog[]
  QuestionGovernanceAudit   QuestionGovernanceAudit[]
  performanceSnapshot       UserPerformanceSnapshot?
  attemptLogs               QuestionAttemptLog[]
  createdFlags              QuestionFlag[]                    @relation("QuestionFlagCreator")
  dismissedRecommendations  QuestionRecommendationDismissal[]
  dismissedIssues           OperationalIssue[]                @relation("IssueDismissedBy")
  assignedIssues            OperationalIssue[]                @relation("IssueAssignedTo")
  operationalIssueAudits    OperationalIssueAudit[]           @relation("OperationalAuditActor")
  createdCompetitions       Competition[]                     @relation("CompetitionCreatedBy")
  updatedCompetitions       Competition[]                     @relation("CompetitionUpdatedBy")
  CompetitionAudit          CompetitionAudit[]
  builderRevisions          BuilderRevision[]
  builderLocks              BuilderLock[]
  publishedVersions         CompetitionVersion[]              @relation("CompetitionVersionPublisher")
  createdSchedules          CompetitionSchedule[]             @relation("ScheduleCreatedBy")
  publishingLocks           PublishingLock[]                  @relation("PublishingLockUser")
  competitionSessions       CompetitionSession[]
  competitionAttempts       CompetitionAttempt[]

  @@index([email])
  @@index([username])
  @@index([accountState])
  @@index([flagged])
  @@index([moderatorStatus])
  @@map("users")
}

enum AccountState {
  ACTIVE
  SUSPENDED
  BANNED
  DEACTIVATED
}

enum ModeratorStatus {
  ACTIVE
  SUSPENDED
  RESTRICTED
  INACTIVE
}

model ModerationNote {
  id          String   @id @default(cuid())
  userId      String
  createdById String
  note        String   @db.Text
  createdAt   DateTime @default(now())
  user        User     @relation("ModerationNoteUser", fields: [userId], references: [id], onDelete: Cascade)
  createdBy   User     @relation("ModerationNoteCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdById])
  @@map("moderation_notes")
}

model ModeratorNote {
  id          String   @id @default(cuid())
  moderatorId String
  createdById String
  note        String   @db.Text
  createdAt   DateTime @default(now())
  moderator   User     @relation("ModeratorNoteModerator", fields: [moderatorId], references: [id], onDelete: Cascade)
  createdBy   User     @relation("ModeratorNoteCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([moderatorId])
  @@index([createdById])
  @@map("moderator_notes")
}

model RoleChangeAudit {
  id           String   @id @default(cuid())
  targetUserId String
  changedById  String
  previousRole UserRole
  newRole      UserRole
  reason       String?  @db.Text
  changedAt    DateTime @default(now())
  targetUser   User     @relation("RoleChangeTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  changedBy    User     @relation("RoleChangeBy", fields: [changedById], references: [id], onDelete: Cascade)

  @@index([targetUserId])
  @@index([changedById])
  @@index([changedAt])
  @@map("role_change_audit")
}

// ─── Global RBAC Governance ─────────────────────────────────────────────────

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  description String?          @db.Text
  category    String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  roles       RolePermission[]

  @@index([category])
  @@index([key])
  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(cuid())
  role         UserRole
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([role, permissionId])
  @@index([role])
  @@index([permissionId])
  @@map("role_permissions")
}

// ─── Sovereign Audit & Governance ─────────────────────────────

enum AuditSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AuditEntityType {
  USER
  CHALLENGE
  QUESTION
  REPORT
  ROLE
  AUTH
  SYSTEM
  MODERATION
  SETTINGS
  SECURITY
  FINANCIAL
  COMPETITION
}

model AuditLog {
  id String @id @default(cuid())

  action     String
  entityType AuditEntityType
  entityId   String?

  actorId      String?
  targetUserId String?

  metadata Json?

  ipAddress String?
  userAgent String?

  severity AuditSeverity @default(LOW)

  createdAt DateTime @default(now())

  actor      User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  targetUser User? @relation("AuditTarget", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([targetUserId])
  @@index([entityType])
  @@index([entityType, entityId])
  @@index([severity])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Financial & Monetization ───────────────────────────────────────────────

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PENDING
  FAILED
}

enum PremiumAccessLevel {
  FREE
  PREMIUM
  HARDCORE
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum TransactionType {
  SUBSCRIPTION
  ONE_TIME_PURCHASE
  REFUND
}

enum PaymentProvider {
  STRIPE
  RAZORPAY
  SYSTEM
}

model SubscriptionPlan {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String? @db.Text
  price       Float
  duration    Int // Duration in days
  features    Json?
  isActive    Boolean @default(true)

  subscriptions UserSubscription[]
  premiumAccess PremiumAccess[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("subscription_plans")
}

model UserSubscription {
  id               String             @id @default(cuid())
  userId           String
  planId           String
  status           SubscriptionStatus @default(PENDING)
  startsAt         DateTime           @default(now())
  expiresAt        DateTime?
  paymentProvider  PaymentProvider    @default(SYSTEM)
  paymentReference String?
  autoRenew        Boolean            @default(false)
  canceledAt       DateTime?

  user User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([planId])
  @@map("user_subscriptions")
}

model PremiumAccess {
  id             String             @id @default(cuid())
  challengeId    String             @unique
  requiredPlanId String?
  accessLevel    PremiumAccessLevel @default(FREE)

  challenge    Challenge         @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  requiredPlan SubscriptionPlan? @relation(fields: [requiredPlanId], references: [id], onDelete: SetNull)

  @@index([challengeId])
  @@index([requiredPlanId])
  @@map("premium_access")
}

model Transaction {
  id         String            @id @default(cuid())
  userId     String
  type       TransactionType
  amount     Float
  status     TransactionStatus @default(PENDING)
  provider   PaymentProvider   @default(SYSTEM)
  providerId String?
  metadata   Json?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("transactions")
}

model RevenueSnapshot {
  id                  String   @id @default(cuid())
  totalRevenue        Float
  monthlyRevenue      Float
  activeSubscriptions Int
  conversionRate      Float
  recordedAt          DateTime @default(now())

  @@index([recordedAt])
  @@map("revenue_snapshots")
}

enum ExamCategory {
  SSC
  BANKING
  RAILWAYS
  STATE_PSC
}

enum PreparationLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@index([provider])
  @@index([providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
  SUPER_ADMIN
}

enum ChallengeDifficulty {
  BEGINNER
  MEDIUM
  HARDCORE
}

enum ChallengeStatus {
  DRAFT
  SCHEDULED
  LIVE
  ENDED
  ARCHIVED
}

enum ChallengeVisibility {
  PUBLIC
  PRIVATE
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  EVALUATED
  ABANDONED
}

enum ViolationType {
  TAB_SWITCH
  WINDOW_BLUR
  COPY_ATTEMPT
  RIGHT_CLICK
}

enum ParticipationType {
  OPEN
  INVITE_ONLY
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

enum QuestionStatus {
  DRAFT
  REVIEW
  APPROVED
  REJECTED
  ARCHIVED
  FLAGGED
}

enum LifecycleState {
  HEALTHY
  INSUFFICIENT_DATA
  MONITORING
  FLAGGED
  REFRESH_REQUIRED
  RETIREMENT_CANDIDATE
}

enum FreshnessStatus {
  FRESH
  AGING
  OUTDATED
  EXPIRED
}

enum RetirementRisk {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum SignalSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum QuestionCategory {
  STATIC
  DYNAMIC
}

enum TriggerSource {
  SYSTEM
  ADMIN
  SUPER_ADMIN
}

enum DataQuality {
  HIGH
  MEDIUM
  LOW
  INSUFFICIENT
}

enum AnalyticsJobStatus {
  STARTED
  COMPLETED
  FAILED
}

model Challenge {
  id                String              @id @default(cuid())
  title             String
  slug              String              @unique
  description       String?             @db.Text
  category          ExamCategory?
  difficulty        ChallengeDifficulty @default(MEDIUM)
  durationInMinutes Int
  totalQuestions    Int                 @default(0)
  visibility        ChallengeVisibility @default(PUBLIC)
  participationType ParticipationType   @default(OPEN)
  status            ChallengeStatus     @default(DRAFT)
  leaderboardFrozen Boolean             @default(false)
  scheduledAt       DateTime?
  startsAt          DateTime?
  endsAt            DateTime?

  // Audit trail
  createdById   String?
  createdBy     User?   @relation(fields: [createdById], references: [id])
  reviewedById  String?
  reviewedBy    User?   @relation("ChallengeReviewer", fields: [reviewedById], references: [id])
  publishedById String?
  publishedBy   User?   @relation("ChallengePublisher", fields: [publishedById], references: [id])

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  questions            ChallengeQuestion[]
  snapshots            ChallengeQuestionSnapshot[]
  attempts             Attempt[]
  leaderboard          LeaderboardEntry[]
  invites              ChallengeInvite[]
  reports              Report[]                    @relation("ReportedChallenge")
  tournamentChallenges TournamentChallenge[]
  premiumAccess        PremiumAccess?

  @@index([slug])
  @@index([category])
  @@index([status])
  @@index([difficulty])
  @@index([scheduledAt])
  @@index([startsAt])
  @@index([endsAt])
  @@index([createdById])
  @@index([reviewedById])
  @@index([publishedById])
  @@index([createdAt])
  @@map("challenges")
}

model Question {
  id              String              @id @default(cuid())
  questionCode    String?             @unique
  question        String              @db.Text
  explanation     String?             @db.Text
  subject         String?
  topic           String?
  category        String?
  examCategory    ExamCategory?
  language        String              @default("en")
  marks           Int                 @default(1)
  negativeMarks   Float               @default(0)
  difficulty      ChallengeDifficulty @default(MEDIUM)
  status          QuestionStatus      @default(DRAFT)
  tags            String[]            @default([])
  version         Int                 @default(1)
  isActive        Boolean             @default(true)
  usageCount      Int                 @default(0)
  createdById     String?
  createdBy       User?               @relation(fields: [createdById], references: [id])
  reviewedById    String?
  reviewedBy      User?               @relation("QuestionReviewer", fields: [reviewedById], references: [id])
  approvedById    String?
  approvedBy      User?               @relation("QuestionApprovedBy", fields: [approvedById], references: [id])
  reviewNotes     String?             @db.Text
  rejectionReason String?             @db.Text
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  reviewedAt      DateTime?

  // Health & Validation Engine
  healthScore            Int?
  healthGrade            String?
  healthStatus           String?
  healthLastCalculatedAt DateTime?

  // Governance & Lifecycle Engine
  lifecycleState           LifecycleState   @default(INSUFFICIENT_DATA)
  governanceScore          Float?
  governanceVersion        Int              @default(1)
  lastGovernanceEvaluation DateTime?
  freshnessStatus          FreshnessStatus?
  retirementRisk           RetirementRisk?
  questionCategory         QuestionCategory @default(STATIC)

  options                  QuestionOption[]
  challenges               ChallengeQuestion[]
  reports                  Report[]                          @relation("ReportedQuestion")
  analytics                QuestionAnalytics?
  QuestionAuditLog         QuestionAuditLog[]
  QuestionGovernanceAudit  QuestionGovernanceAudit[]
  usageStats               QuestionUsageStats?
  attemptLogs              QuestionAttemptLog[]
  flags                    QuestionFlag[]
  recommendationDismissals QuestionRecommendationDismissal[]
  operationalIssues        OperationalIssue[]
  competitions             CompetitionQuestion[]

  @@index([questionCode])
  @@index([category])
  @@index([subject])
  @@index([topic])
  @@index([difficulty])
  @@index([status])
  @@index([createdById])
  @@index([reviewedById])
  @@index([approvedById])
  @@index([createdAt])
  @@index([status, category, difficulty])
  @@index([updatedAt])
  @@map("questions")
}

model QuestionOption {
  id         String   @id @default(cuid())
  questionId String
  optionText String
  isCorrect  Boolean  @default(false)
  order      Int      @default(0)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@map("question_options")
}

// ─── Question Bank Governance ────────────────────────────────

enum QuestionAuditAction {
  CREATED
  UPDATED
  SUBMITTED_FOR_REVIEW
  APPROVED
  REJECTED
  FLAGGED
  ARCHIVED
  VERSION_CREATED
  SNAPSHOT_GENERATED
  BULK_IMPORTED
}

model QuestionAuditLog {
  id String @id @default(cuid())

  questionId String

  actorId String

  action QuestionAuditAction

  previousStatus QuestionStatus?
  nextStatus     QuestionStatus?

  previousVersion Int?
  nextVersion     Int?

  reason String?

  metadata Json?

  createdAt DateTime @default(now())

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  actor    User     @relation(fields: [actorId], references: [id])

  @@index([questionId])
  @@index([actorId])
  @@index([action])
  @@index([createdAt])
  @@index([questionId, action, createdAt(sort: Desc)])
  @@map("question_audit_logs")
}

model QuestionGovernanceAudit {
  id            String        @id @default(cuid())
  questionId    String
  action        String
  reason        String?       @db.Text
  adminId       String?
  triggerSource TriggerSource

  previousState LifecycleState?
  newState      LifecycleState

  timestamp DateTime @default(now())

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  admin    User?    @relation(fields: [adminId], references: [id], onDelete: SetNull)

  @@index([questionId])
  @@index([adminId])
  @@index([timestamp])
  @@map("question_governance_audits")
}

model QuestionCodeCounter {
  id       String @id @default(cuid())
  category String @unique
  counter  Int    @default(0)

  @@map("question_code_counters")
}

enum ImportJobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

model QuestionImportJob {
  id String @id @default(cuid())

  uploadedById String

  fileName String
  fileType String
  fileSize Int    @default(0)

  status ImportJobStatus @default(QUEUED)

  // Stats
  totalRows     Int @default(0)
  validRows     Int @default(0)
  invalidRows   Int @default(0)
  warningRows   Int @default(0)
  duplicateRows Int @default(0)

  // Progress & Execution
  progressPercentage Int     @default(0)
  processedRows      Int     @default(0)
  failureReason      String? @db.Text

  // Health & Metrics
  averageHealthScore      Int?
  highestHealthScore      Int?
  lowestHealthScore       Int?
  questionsBelowThreshold Int?

  startedAt   DateTime  @default(now())
  completedAt DateTime?
  durationMs  Int?

  errorReport Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  uploadedBy User          @relation(fields: [uploadedById], references: [id])
  issues     ImportIssue[]
  report     ImportReport?

  @@index([status])
  @@map("question_import_jobs")
}

enum IssueSeverity {
  WARNING
  ERROR
}

model ImportIssue {
  id           String        @id @default(cuid())
  importJobId  String
  rowNumber    Int
  severity     IssueSeverity
  message      String        @db.Text
  suggestedFix String?       @db.Text

  createdAt DateTime @default(now())

  job QuestionImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)

  @@index([importJobId])
  @@map("import_issues")
}

model ImportReport {
  id    String @id @default(cuid())
  jobId String @unique

  duplicatesPrevented     Int @default(0)
  totalImported           Int @default(0)
  averageHealthScore      Int @default(0)
  highestHealthScore      Int @default(0)
  lowestHealthScore       Int @default(0)
  questionsBelowThreshold Int @default(0)
  failedRows              Int @default(0)

  job QuestionImportJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("import_reports")
}

model ImportAudit {
  id            String @id @default(cuid())
  jobId         String
  performedById String

  action   String
  fileName String

  rowsImported  Int @default(0)
  warningsCount Int @default(0)
  errorsCount   Int @default(0)

  performedAt DateTime @default(now())

  @@index([jobId])
  @@index([performedById])
  @@map("import_audits")
}

model ChallengeQuestion {
  id String @id @default(cuid())

  challengeId String
  questionId  String

  orderIndex Int

  marks Int @default(1)

  isMandatory Boolean @default(true)

  createdAt DateTime @default(now())

  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  question  Question  @relation(fields: [questionId], references: [id])

  @@unique([challengeId, questionId])
  @@index([challengeId])
  @@index([questionId])
  @@map("challenge_questions")
}

model ChallengeQuestionSnapshot {
  id String @id @default(cuid())

  challengeId String

  originalQuestionId String

  questionVersion Int

  questionCode String

  question String
  options  Json

  correctOption String

  explanation String?

  category   String
  subject    String
  difficulty ChallengeDifficulty

  tags String[]

  language String

  orderIndex Int

  createdAt DateTime @default(now())

  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@index([challengeId])
  @@index([originalQuestionId])
  @@map("challenge_question_snapshots")
}

model Attempt {
  id          String        @id @default(cuid())
  userId      String
  challengeId String
  status      AttemptStatus @default(IN_PROGRESS)

  // Scoring
  score           Int @default(0)
  correctAnswers  Int @default(0)
  wrongAnswers    Int @default(0)
  unansweredCount Int @default(0)
  totalAnswered   Int @default(0)

  // Timing
  startedAt          DateTime  @default(now())
  submittedAt        DateTime?
  expiresAt          DateTime?
  timeTakenInSeconds Int?
  isAutoSubmitted    Boolean   @default(false)

  // Randomization
  questionOrder Json?
  optionOrders  Json?

  // Anti-cheat
  isFlagged       Boolean @default(false)
  tabSwitchCount  Int     @default(0)
  blurCount       Int     @default(0)
  totalViolations Int     @default(0)

  // Relations
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge        Challenge         @relation(fields: [challengeId], references: [id])
  answers          AttemptAnswer[]
  antiCheatLogs    AntiCheatLog[]
  leaderboardEntry LeaderboardEntry?

  tournamentId String?
  tournament   Tournament? @relation(fields: [tournamentId], references: [id])

  @@unique([userId, challengeId])
  @@index([userId])
  @@index([challengeId])
  @@index([status])
  @@index([submittedAt])
  @@index([isFlagged])
  @@index([userId, status])
  @@index([challengeId, status])
  @@map("attempts")
}

model AttemptAnswer {
  id                 String    @id @default(cuid())
  attemptId          String
  questionId         String
  selectedOption     String?
  selectedOptionId   String?
  isCorrect          Boolean?
  isSkipped          Boolean   @default(false)
  timeSpentInSeconds Int?
  answeredAt         DateTime? @default(now())

  attempt Attempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@index([questionId])
  @@map("attempt_answers")
}

// ─── Leaderboard ─────────────────────────────────────────────

model LeaderboardEntry {
  id                 String    @id @default(cuid())
  challengeId        String
  userId             String
  attemptId          String    @unique
  rank               Int
  score              Int
  accuracy           Float
  timeTakenInSeconds Int
  correctAnswers     Int       @default(0)
  totalQuestions     Int       @default(0)
  category           String?
  submittedAt        DateTime?
  frozenAt           DateTime  @default(now())

  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  attempt   Attempt   @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@unique([challengeId, userId])
  @@index([challengeId, rank])
  @@index([category, score])
  @@index([category, rank])
  @@index([userId])
  @@index([challengeId])
  @@index([challengeId, score(sort: Desc)])
  @@map("leaderboard_entries")
}

