  type           QuestionType
  structure      Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  @@index([organizationId])
  @@map("question_templates")
}

model Question {
  id                       String                            @id @default(cuid())
  organizationId           String?
  bankId                   String
  type                     QuestionType
  currentRevisionId        String?
  status                   QuestionStatus                    @default(ACTIVE)
  createdAt                DateTime                          @default(now())
  updatedAt                DateTime                          @updatedAt
  createdById              String?
  deletedAt                DateTime?
  challenges               ChallengeQuestion[]
  competitions             CompetitionQuestion[]
  operationalIssues        OperationalIssue[]
  analytics                QuestionAnalytics?
  attemptLogs              QuestionAttemptLog[]
  QuestionAuditLog         QuestionAuditLog[]
  flags                    QuestionFlag[]
  QuestionGovernanceAudit  QuestionGovernanceAudit[]
  recommendationDismissals QuestionRecommendationDismissal[]
  revisions                QuestionRevision[]
  usageStats               QuestionUsageStats?
  bank                     QuestionBank                      @relation(fields: [bankId], references: [id], onDelete: Cascade)
  createdBy                User?                             @relation(fields: [createdById], references: [id])
  reports                  Report[]                          @relation("ReportedQuestion")

  @@index([organizationId])
  @@index([bankId])
  @@index([currentRevisionId])
  @@map("questions")
}

model QuestionRevision {
  id             String                    @id @default(cuid())
  questionId     String
  organizationId String?
  revisionNumber Int                       @default(1)
  version        Int                       @default(1)
  status         RevisionStatus            @default(DRAFT)
  sourceType     QuestionSourceType        @default(MANUAL)
  difficulty     QuestionDifficulty        @default(MEDIUM)
  language       QuestionLanguage          @default(EN)
  chapterId      String?
  publishedAt    DateTime?
  publishedById  String?
  reviewedAt     DateTime?
  reviewedBy     String?
  approvedAt     DateTime?
  approvedBy     String?
  archivedAt     DateTime?
  archivedById   String?
  revisionReason String?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  deletedAt      DateTime?
  assets         QuestionAssetAssignment[]
  explanation    QuestionExplanation?
  hints          QuestionHint[]
  instruction    QuestionInstruction?
  optionGroups   QuestionOptionGroup[]
  options        QuestionOption[]
  passage        QuestionPassage?
  references     QuestionReference[]
  chapter        Chapter?                  @relation(fields: [chapterId], references: [id])
  question       Question                  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  statement      QuestionStatement?

  @@index([questionId])
  @@index([chapterId])
  @@index([status])
  @@index([difficulty])
  @@index([language])
  @@map("question_revisions")
}

model Subject {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  topics      Topic[]

  @@map("subjects")
}

model Topic {
  id          String    @id @default(cuid())
  subjectId   String
  name        String
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  chapters    Chapter[]
  subject     Subject   @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@index([subjectId])
  @@map("topics")
}

model Chapter {
  id          String             @id @default(cuid())
  topicId     String
  name        String
  description String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  topic       Topic              @relation(fields: [topicId], references: [id], onDelete: Cascade)
  revisions   QuestionRevision[]

  @@index([topicId])
  @@map("chapters")
}

model QuestionStatement {
  id         String           @id @default(cuid())
  revisionId String           @unique
  content    String
  revision   QuestionRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)

  @@map("question_statements")
}

model QuestionExplanation {
  id         String           @id @default(cuid())
  revisionId String           @unique
  content    String
  revision   QuestionRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)

  @@map("question_explanations")
}

model QuestionInstruction {
  id         String           @id @default(cuid())
  revisionId String           @unique
  content    String
  revision   QuestionRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)

  @@map("question_instructions")
}

model QuestionPassage {
  id         String           @id @default(cuid())
  revisionId String           @unique
  content    String
  revision   QuestionRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)

  @@map("question_passages")
}

model QuestionHint {
  id           String           @id @default(cuid())
  revisionId   String
  content      String
  displayOrder Int              @default(0)
  revision     QuestionRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)

  @@index([revisionId])
  @@map("question_hints")
}

model QuestionReference {
  id           String           @id @default(cuid())
  revisionId   String
  content      String
  url          String?
  displayOrder Int              @default(0)
  revision     QuestionRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)

  @@index([revisionId])
  @@map("question_references")
}

model QuestionOptionGroup {
  id           String           @id @default(cuid())
  revisionId   String
  name         String
  displayOrder Int              @default(0)
  revision     QuestionRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  options      QuestionOption[]

  @@index([revisionId])
  @@map("question_option_groups")
}

model QuestionOption {
  id           String                    @id @default(cuid())
  revisionId   String
  groupId      String?
  content      String
  isCorrect    Boolean                   @default(false)
  displayOrder Int                       @default(0)
  assets       QuestionAssetAssignment[]
  group        QuestionOptionGroup?      @relation(fields: [groupId], references: [id])
  revision     QuestionRevision          @relation(fields: [revisionId], references: [id], onDelete: Cascade)

  @@index([revisionId])
  @@index([groupId])
  @@map("question_options")
}

model QuestionAsset {
  id             String                    @id @default(cuid())
  organizationId String?
  url            String
  assetType      String
  fileName       String?
  fileSize       Int?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  deletedAt      DateTime?
  assignments    QuestionAssetAssignment[]

  @@index([organizationId])
  @@map("question_assets")
}

model QuestionAssetAssignment {
  id             String              @id @default(cuid())
  assetId        String
  revisionId     String?
  optionId       String?
  assignmentType AssetAssignmentType
  displayOrder   Int                 @default(0)
  asset          QuestionAsset       @relation(fields: [assetId], references: [id], onDelete: Cascade)
  option         QuestionOption?     @relation(fields: [optionId], references: [id], onDelete: Cascade)
  revision       QuestionRevision?   @relation(fields: [revisionId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@index([revisionId])
  @@index([optionId])
  @@map("question_asset_assignments")
}

