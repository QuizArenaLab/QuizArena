enum OperationalIssueSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum OperationalIssueStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  DISMISSED
  AUTO_RESOLVED
}

enum OperationalAuditAction {
  DETECTED
  RESOLVED
  DISMISSED
  REOPENED
  AUTO_RESOLVED
  SEVERITY_INCREASED
  ASSIGNED
}

model OperationalRule {
  id          String                   @id @default(cuid())
  ruleKey     String                   @unique
  enabled     Boolean                  @default(true)
  severity    OperationalIssueSeverity
  threshold   Float
  description String?

  @@map("operational_rules")
}

model OperationalIssue {
  id               String                    @id @default(cuid())
  issueFingerprint String                    @unique
  questionId       String
  issueType        String
  severity         OperationalIssueSeverity
  previousSeverity OperationalIssueSeverity?
  status           OperationalIssueStatus    @default(OPEN)
  priority         OperationalIssueSeverity  @default(LOW)

  detectedAt      DateTime  @default(now())
  lastEvaluatedAt DateTime  @default(now())
  resolvedAt      DateTime?

  dismissedById String?
  dismissedAt   DateTime?

  assignedToId String?
  dueDate      DateTime?

  resolutionNotes String? @db.Text

  question    Question                @relation(fields: [questionId], references: [id], onDelete: Cascade)
  dismissedBy User?                   @relation("IssueDismissedBy", fields: [dismissedById], references: [id], onDelete: SetNull)
  assignedTo  User?                   @relation("IssueAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  audits      OperationalIssueAudit[]

  @@index([questionId])
  @@index([issueType])
  @@index([status])
  @@index([severity])
  @@index([priority])
  @@index([assignedToId])
  @@map("operational_issues")
}

model OperationalIssueAudit {
  id        String                 @id @default(cuid())
  issueId   String
  action    OperationalAuditAction
  actorId   String?
  reason    String?                @db.Text
  createdAt DateTime               @default(now())

  issue OperationalIssue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  actor User?            @relation("OperationalAuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([issueId])
  @@index([actorId])
  @@index([action])
  @@map("operational_issue_audits")
}

// ─── Competition Domain ─────────────────────────────────────

enum CompetitionType {
  OPEN_PRACTICE
  FREE_CHALLENGE
  PAID_CHALLENGE
  MOCK_TEST
  TOURNAMENT
}

enum CompetitionLifecycle {
  DRAFT
  READY
  SCHEDULED
  LIVE
  PAUSED
  COMPLETED
  EXPIRED
  ARCHIVED
  CANCELLED
}

enum CompetitionHealthStatus {
  HEALTHY
  WARNING
  CRITICAL
}

enum LifecycleActorType {
  SYSTEM
  ADMIN
  SUPER_ADMIN
  WORKER
  API
}

enum BulkJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum CompetitionStatus {
  DRAFT
  READY
  PUBLISHING
  SCHEDULED
  LIVE
  COMPLETED
  EXPIRED
  ARCHIVED
  ACTIVE
  INACTIVE
  DELETED
}

enum CompetitionVisibility {
  PUBLIC
  PRIVATE
  INVITE_ONLY
}

enum CompetitionAuditAction {
  CREATED
  UPDATED
  QUESTIONS_ATTACHED
  QUESTIONS_DETACHED
  QUESTIONS_REORDERED
  RULES_CONFIGURED
  ELIGIBILITY_CONFIGURED
  ECONOMICS_CONFIGURED
  SECTIONS_CONFIGURED
  VALIDATED
  VALIDATION_FAILED
  MARKED_READY
  PUBLISHED
  SCHEDULED
  WENT_LIVE
  COMPLETED
  EXPIRED
  ARCHIVED
  RESTORED
  CLONED
  VERSION_CREATED
  PURGED
  ROLLBACK
  SCHEDULE_PUBLISH
  SCHEDULE_EXPIRE
  PUBLISH_STARTED
  PUBLISH_FAILED
}

model Competition {
  id          String  @id @default(cuid())
  title       String
  slug        String  @unique
  description String? @db.Text

  // Classification
  competitionType CompetitionType
  status          CompetitionStatus       @default(INACTIVE)
  lifecycleState  CompetitionLifecycle    @default(DRAFT)
  readinessScore  Int                     @default(0)
  healthStatus    CompetitionHealthStatus @default(HEALTHY)
  visibility      CompetitionVisibility   @default(PUBLIC)
  exam            ExamCategory?
  difficulty      ChallengeDifficulty     @default(MEDIUM)
  language        String                  @default("en")

  // Core metrics (denormalized for fast queries)
  durationMinutes Int
  totalQuestions  Int @default(0)
  maximumMarks    Int @default(0)

  // Versioning
  version                 Int     @default(1)
  lifecycleVersion        Int     @default(1)
  isLatestVersion         Boolean @default(true)
  clonedFromCompetitionId String?

  // Scheduling
  startsAt           DateTime?
  endsAt             DateTime?
  scheduledStart     DateTime?
  scheduledEnd       DateTime?
  publishedAt        DateTime?
  scheduledPublishAt DateTime?
  scheduledExpiryAt  DateTime?

  // Lifecycle Timestamps
  activatedAt         DateTime?
  completedAt         DateTime?
  expiredAt           DateTime?
  archivedAt          DateTime?
  cancelledAt         DateTime?
  lastLifecycleUpdate DateTime?
  lastLifecycleActor  String?

  // Audit trail
  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // ─── Relations ──────────────────────────────────
  createdBy  User?         @relation("CompetitionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy  User?         @relation("CompetitionUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  clonedFrom Competition?  @relation("CompetitionClones", fields: [clonedFromCompetitionId], references: [id], onDelete: SetNull)
  clones     Competition[] @relation("CompetitionClones")

  // Sub-configurations
  config      CompetitionConfig?
  economics   CompetitionEconomics?
  eligibility CompetitionEligibility?

  // Content
  sections       CompetitionSection[]
  questions      CompetitionQuestion[]
  auditTrail     CompetitionAudit[]
  versions       CompetitionVersion[]
  schedule       CompetitionSchedule?
  publishingLock PublishingLock?
  revisions      BuilderRevision[]
  locks          BuilderLock[]
  sessions       CompetitionSession[]
  attempts       CompetitionAttempt[]
  lifecycleAudits CompetitionLifecycleAudit[]

  @@index([slug])
  @@index([competitionType])
  @@index([status])
  @@index([visibility])
  @@index([exam])
  @@index([difficulty])
  @@index([startsAt])
  @@index([endsAt])
  @@index([createdById])
  @@index([createdAt])
  @@index([status, competitionType])
  @@index([status, visibility])
  @@index([isLatestVersion])
  @@index([clonedFromCompetitionId])
  @@map("competitions")
}

model CompetitionConfig {
  id            String @id @default(cuid())
  competitionId String @unique

  // Rules (versioned JSON — structured via TypeScript interface)
  rules        Json?
  rulesVersion Int   @default(1)

  // Behavior flags
  negativeMarkingEnabled  Boolean @default(false)
  negativeMarkPerQuestion Float   @default(0)
  passingMarks            Int?
  allowRetake             Boolean @default(false)
  randomizeQuestions      Boolean @default(false)
  randomizeOptions        Boolean @default(false)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  competition Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)

  @@index([competitionId])
  @@map("competition_configs")
}

model CompetitionEconomics {
  id            String @id @default(cuid())
  competitionId String @unique

  entryFee   Float  @default(0)
  rewardPool Float  @default(0)
  currency   String @default("INR")

  // Future: prize distribution, sponsor metadata
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  competition Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)

  @@index([competitionId])
  @@map("competition_economics")
}

model CompetitionEligibility {
  id            String @id @default(cuid())
  competitionId String @unique

  // Eligibility criteria (versioned JSON — structured via TypeScript interface)
  criteria           Json?
  eligibilityVersion Int   @default(1)

  maxParticipants Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  competition Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)

  @@index([competitionId])
  @@map("competition_eligibility")
}

model CompetitionSection {
  id            String @id @default(cuid())
  competitionId String

  title        String
  slug         String
  description  String? @db.Text
  instructions String? @db.Text
  displayOrder Int     @default(0)

  // Section-level overrides
  durationMinutes Int?
  totalQuestions  Int     @default(0)
  maximumMarks    Int     @default(0)
  passingMarks    Int?
  isMandatory     Boolean @default(true)
  allowNavigation Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  competition Competition           @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  questions   CompetitionQuestion[]

  @@unique([competitionId, slug])
  @@index([competitionId])
  @@index([displayOrder])
  @@map("competition_sections")
}

model CompetitionQuestion {
  id            String  @id @default(cuid())
  competitionId String
  questionId    String
  sectionId     String?

  // Ordering
  displayOrder Int @default(0)
  sectionOrder Int @default(0)

  // Scoring
  marks          Int   @default(1)
  negativeMarks  Float @default(0)
  questionWeight Float @default(1.0)

  // Overrides
  difficultyOverride ChallengeDifficulty?
  timeLimitOverride  Int? // seconds — overrides competition-level timer for this question

  // Flags
  isOptional  Boolean @default(false)
  isBonus     Boolean @default(false)
  isMandatory Boolean @default(true)

  createdAt DateTime @default(now())

  competition Competition         @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  question    Question            @relation(fields: [questionId], references: [id])
  section     CompetitionSection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)

  @@unique([competitionId, questionId])
  @@index([competitionId])
  @@index([questionId])
  @@index([sectionId])
  @@index([displayOrder])
  @@map("competition_questions")
}

model CompetitionAudit {
  id            String                 @id @default(cuid())
  competitionId String
  action        CompetitionAuditAction
  actorId       String?
  previousState CompetitionStatus?
  newState      CompetitionStatus?
  reason        String?                @db.Text
  metadata      Json?
  createdAt     DateTime               @default(now())

  competition Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  actor       User?       @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([competitionId])
  @@index([actorId])
  @@index([action])
  @@index([createdAt])
  @@index([competitionId, createdAt(sort: Desc)])
  @@map("competition_audits")
}

model CompetitionLifecycleAudit {
  id              String               @id @default(cuid())
  competitionId   String
  previousState   CompetitionLifecycle?
  newState        CompetitionLifecycle
  reason          String?              @db.Text
  performedBy     String?
  performedByType LifecycleActorType
  metadata        Json?
  createdAt       DateTime             @default(now())

  competition Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)

  @@index([competitionId])
  @@index([createdAt])
  @@index([newState])
  @@map("competition_lifecycle_audits")
}

model BulkOperationJob {
  id             String        @id @default(cuid())
  operationType  String
  status         BulkJobStatus @default(PENDING)
  totalItems     Int
  processedItems Int           @default(0)
  failedItems    Int           @default(0)
  results        Json?
  startedBy      String?

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  completedAt    DateTime?

  @@index([status])
  @@index([createdAt])
  @@map("bulk_operation_jobs")
}

model BuilderRevision {
  id             String   @id @default(cuid())
  competitionId  String
  revisionNumber Int
  actorId        String?
  summary        String?  @db.Text
  snapshot       Json
  createdAt      DateTime @default(now())

  competition Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  actor       User?       @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@unique([competitionId, revisionNumber])
  @@index([competitionId])
  @@index([createdAt])
  @@map("builder_revisions")
}

model BuilderLock {
  id            String   @id @default(cuid())
  competitionId String   @unique
  userId        String
  expiresAt     DateTime

  competition Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([competitionId])
  @@index([expiresAt])
  @@map("builder_locks")
}

model CompetitionVersion {
  id            String @id @default(cuid())
  competitionId String
  versionNumber Int

  // Structured snapshot (NOT one huge JSON)
  competitionSnapshot Json // Core competition fields
  sectionsSnapshot    Json // Sections array
  questionsSnapshot   Json // Question mappings array
  rulesSnapshot       Json // Rules + config
  configSnapshot      Json // Economics + eligibility

  changelog     String?   @db.Text
  publishedAt   DateTime?
  publishedById String?
  isActive      Boolean   @default(false)
  createdAt     DateTime  @default(now())

  competition Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  publishedBy User?       @relation("CompetitionVersionPublisher", fields: [publishedById], references: [id], onDelete: SetNull)

  @@unique([competitionId, versionNumber])
  @@index([competitionId])
  @@index([isActive])
  @@map("competition_versions")
}

model CompetitionSchedule {
  id            String @id @default(cuid())
  competitionId String @unique

  publishAt DateTime?
  expiresAt DateTime?
  timezone  String         @default("Asia/Kolkata")
  status    ScheduleStatus @default(PENDING)

  executedAt   DateTime?
  executionLog String?   @db.Text

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  competition Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  createdBy   User?       @relation("ScheduleCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([competitionId])
  @@index([publishAt])
  @@index([status])
  @@map("competition_schedules")
}

enum ScheduleStatus {
  PENDING
  EXECUTING
  COMPLETED
  FAILED
  CANCELLED
}

model PublishingLock {
  id            String   @id @default(cuid())
  competitionId String   @unique
  userId        String
  acquiredAt    DateTime @default(now())
  expiresAt     DateTime

  competition Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  user        User        @relation("PublishingLockUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([competitionId])
  @@index([expiresAt])
  @@map("publishing_locks")
}

// ─── Competition Experience Engine ───────────────────────────────

enum SessionState {
  INITIALIZING
  READY
  IN_PROGRESS
  PAUSED
  SUBMITTING
  SUBMITTED
  EXPIRED
  ABANDONED
}

model CompetitionSession {
  id            String       @id @default(cuid())
  competitionId String
  userId        String
  status        SessionState @default(INITIALIZING)

  // Timing (Server-Authoritative)
  startedAt DateTime  @default(now())
  expiresAt DateTime?

  // Randomization (Deterministic)
  shuffleSeed   String
  questionOrder Json?
  optionOrder   Json?

  // Anti-cheat (Lightweight)
  tabSwitchCount Int @default(0)
  blurCount      Int @default(0)

  // Relations
  competition Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  answers   CompetitionSessionAnswer[]
  auditLogs CompetitionSessionAuditLog[]
  attempt   CompetitionAttempt?

  @@unique([userId, competitionId])
  @@index([competitionId, status])
  @@index([userId, status])
  @@map("competition_sessions")
}

model CompetitionSessionAnswer {
  id                String    @id @default(cuid())
  sessionId         String
  questionId        String
  selectedOptionId  String?
  isVisited         Boolean   @default(true)
  isMarkedForReview Boolean   @default(false)
  answeredAt        DateTime? @default(now())

  session CompetitionSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, questionId])
  @@map("competition_session_answers")
}

model CompetitionAttempt {
  id            String @id @default(cuid())
  sessionId     String @unique
  competitionId String
  userId        String

  // This model is generated upon submission and is immutable.
  // It represents the final state of the attempt to be processed by the Evaluation Engine.
  submittedAt DateTime @default(now())

  score              Int     @default(0)
  accuracy           Float   @default(0)
  percentage         Float   @default(0)
  correctAnswers     Int     @default(0)
  wrongAnswers       Int     @default(0)
  unansweredCount    Int     @default(0)
  timeTakenInSeconds Int     @default(0)
  
  evaluationSnapshot Json?
  resultSnapshot     Json?
  fraudAssessment    Json?
  
  pipelineMetrics    Json?

  session     CompetitionSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  competition Competition        @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, competitionId])
  @@index([competitionId])
  @@index([userId])
  @@map("competition_attempts")
}

model CompetitionSessionAuditLog {
  id        String   @id @default(cuid())
  sessionId String
  type      String
  metadata  Json?
  createdAt DateTime @default(now())

  session CompetitionSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("competition_session_audit_logs")
}
