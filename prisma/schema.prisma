  totalScore               Int        @default(0)
  averageAccuracy          Float      @default(0)
  totalChallengesCompleted Int        @default(0)
  rank                     Int        @default(0)

  updatedAt DateTime @updatedAt

  @@unique([userId, tournamentId])
  @@index([tournamentId, rank])
  @@index([userId])
  @@map("tournament_leaderboards")
}

