generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String             @id @default(cuid())
  name                String?
  username            String?            @unique
  email               String?            @unique
  emailVerified       DateTime?
  image               String?
  password            String?
  role                UserRole           @default(USER)
  onboardingCompleted Boolean            @default(false)
  examCategory        ExamCategory?
  preparationLevel   PreparationLevel?
  accountState        AccountState       @default(ACTIVE)
  flagged             Boolean            @default(false)
  moderatorStatus     ModeratorStatus    @default(ACTIVE)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  accounts            Account[]
  sessions            Session[]
  attempts            ChallengeAttempt[]
  createdChallenges   Challenge[]
  reviewedChallenges   Challenge[]        @relation("ChallengeReviewer")
  publishedChallenges Challenge[]        @relation("ChallengePublisher")
  createdQuestions    Question[]
  reviewedQuestions  Question[]          @relation("QuestionReviewer")
  moderationNotes     ModerationNote[]   @relation("ModerationNoteUser")
  createdByNotes      ModerationNote[]   @relation("ModerationNoteCreator")
  moderatorNotes      ModeratorNote[]    @relation("ModeratorNoteModerator")
  createdByModNotes  ModeratorNote[]     @relation("ModeratorNoteCreator")
  roleChangesAsTarget RoleChangeAudit[]  @relation("RoleChangeTarget")
  roleChangesAsActor  RoleChangeAudit[]  @relation("RoleChangeBy")
  submittedReports    Report[]           @relation("ReportSubmitter")
  targetedReports     Report[]           @relation("ReportTarget")
  reviewedReports     Report[]           @relation("ReportReviewer")
  reportNotes         ReportNote[]       @relation("ReportNoteAuthor")
  updatedSettings     PlatformSetting[]  @relation("SettingUpdater")
  settingAudits       SettingAudit[]     @relation("SettingAuditActor")

  @@index([email])
  @@index([username])
  @@index([accountState])
  @@index([flagged])
  @@index([moderatorStatus])
  @@map("users")
}

enum AccountState {
  ACTIVE
  SUSPENDED
  BANNED
  DEACTIVATED
}

enum ModeratorStatus {
  ACTIVE
  SUSPENDED
  RESTRICTED
  INACTIVE
}

model ModerationNote {
  id         String   @id @default(cuid())
  userId     String
  createdById String
  note       String   @db.Text
  createdAt  DateTime @default(now())
  user       User     @relation("ModerationNoteUser", fields: [userId], references: [id], onDelete: Cascade)
  createdBy  User     @relation("ModerationNoteCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdById])
  @@map("moderation_notes")
}

model ModeratorNote {
  id           String   @id @default(cuid())
  moderatorId  String
  createdById  String
  note         String   @db.Text
  createdAt    DateTime @default(now())
  moderator    User     @relation("ModeratorNoteModerator", fields: [moderatorId], references: [id], onDelete: Cascade)
  createdBy    User     @relation("ModeratorNoteCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([moderatorId])
  @@index([createdById])
  @@map("moderator_notes")
}

model RoleChangeAudit {
  id            String   @id @default(cuid())
  targetUserId  String
  changedById   String
  previousRole  UserRole
  newRole       UserRole
  reason        String?  @db.Text
  changedAt     DateTime @default(now())
  targetUser    User     @relation("RoleChangeTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  changedBy     User     @relation("RoleChangeBy", fields: [changedById], references: [id], onDelete: Cascade)

  @@index([targetUserId])
  @@index([changedById])
  @@index([changedAt])
  @@map("role_change_audit")
}

enum ExamCategory {
  SSC
  BANKING
  RAILWAYS
  STATE_PSC
}

enum PreparationLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@index([provider])
  @@index([providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
  SUPER_ADMIN
}

enum ChallengeDifficulty {
  EASY
  MEDIUM
  HARD
}

enum ChallengeStatus {
  DRAFT
  REVIEW
  SCHEDULED
  PUBLISHED
  EXPIRED
  ARCHIVED
}

enum QuestionStatus {
  DRAFT
  REVIEW
  APPROVED
  REJECTED
  ARCHIVED
}

model Challenge {
  id               String              @id @default(cuid())
  title            String
  slug             String              @unique
  description      String?             @db.Text
  instructions     String?             @db.Text
  examCategory     ExamCategory?
  difficulty       ChallengeDifficulty @default(MEDIUM)
  durationInMinutes Int
  totalQuestions   Int                 @default(0)
  totalMarks       Int                 @default(0)
  negativeMarking  Boolean             @default(false)
  negativeMarkPercentage Float          @default(0.25)
  status           ChallengeStatus     @default(DRAFT)
  createdById      String?
  createdBy        User?               @relation(fields: [createdById], references: [id])
  reviewedById     String?
  reviewedBy       User?               @relation("ChallengeReviewer", fields: [reviewedById], references: [id])
  publishedById    String?
  publishedBy      User?               @relation("ChallengePublisher", fields: [publishedById], references: [id])
  reviewNotes      String?             @db.Text
  rejectionReason String?             @db.Text
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  reviewedAt       DateTime?
  scheduledPublishAt DateTime?
  publishedAt      DateTime?
  expiresAt        DateTime?
  archivedAt        DateTime?
  questions        ChallengeQuestion[]
  attempts        ChallengeAttempt[]
  reports         Report[]            @relation("ReportedChallenge")

  @@index([slug])
  @@index([examCategory])
  @@index([status])
  @@index([difficulty])
  @@index([scheduledPublishAt])
  @@index([publishedAt])
  @@index([expiresAt])
  @@index([createdById])
  @@index([reviewedById])
  @@index([createdAt])
  @@map("challenges")
}

model Question {
  id            String              @id @default(cuid())
  question      String              @db.Text
  explanation   String?             @db.Text
  subject       String?
  topic         String?
  language      String              @default("en")
  marks         Int                 @default(1)
  negativeMarks Float               @default(0)
  difficulty    ChallengeDifficulty @default(MEDIUM)
  status        QuestionStatus      @default(DRAFT)
  createdById   String?
  createdBy     User?               @relation(fields: [createdById], references: [id])
  reviewedById  String?
  reviewedBy    User?               @relation("QuestionReviewer", fields: [reviewedById], references: [id])
  reviewNotes  String?             @db.Text
  rejectionReason String?           @db.Text
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  reviewedAt    DateTime?
  options       QuestionOption[]
  challenges    ChallengeQuestion[]
  reports       Report[]            @relation("ReportedQuestion")

  @@index([subject])
  @@index([topic])
  @@index([difficulty])
  @@index([status])
  @@index([createdById])
  @@index([reviewedById])
  @@index([createdAt])
  @@map("questions")
}

model QuestionOption {
  id          String   @id @default(cuid())
  questionId  String
  optionText  String
  isCorrect   Boolean  @default(false)
  order       Int      @default(0)
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@map("question_options")
}

model ChallengeQuestion {
  id          String    @id @default(cuid())
  challengeId String
  questionId  String
  order       Int       @default(0)
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  question    Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([challengeId, questionId])
  @@index([challengeId])
  @@index([questionId])
  @@map("challenge_questions")
}

model ChallengeAttempt {
  id               String       @id @default(cuid())
  userId           String
  challengeId      String
  score            Int          @default(0)
  correctAnswers  Int          @default(0)
  wrongAnswers    Int          @default(0)
  unanswered       Int          @default(0)
  startedAt        DateTime     @default(now())
  submittedAt      DateTime?
  timeTakenInSeconds Int?
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge        Challenge   @relation(fields: [challengeId], references: [id])
  answers          UserAnswer[]

  @@index([userId])
  @@index([challengeId])
  @@index([submittedAt])
  @@map("challenge_attempts")
}

model UserAnswer {
  id            String            @id @default(cuid())
  attemptId     String
  questionId    String
  selectedOption String?
  isCorrect     Boolean?
  isSkipped     Boolean           @default(false)
  timeSpentInSeconds Int?
  attempt       ChallengeAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@index([questionId])
  @@map("user_answers")
}

model QuestionAnalytics {
  id                String   @id @default(cuid())
  questionId        String   @unique
  totalAttempts    Int      @default(0)
  correctAttempts  Int      @default(0)
  wrongAttempts    Int      @default(0)
  skippedAttempts  Int      @default(0)
  totalTimeSpent    Int      @default(0)
  averageTimeSpent  Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([questionId])
  @@map("question_analytics")
}

model ChallengeAnalytics {
  id               String   @id @default(cuid())
  challengeId      String   @unique
  totalAttempts   Int      @default(0)
  completedAttempts Int    @default(0)
  totalScore      Float    @default(0)
  averageScore    Float    @default(0)
  highestScore    Int      @default(0)
  lowestScore     Int      @default(0)
  averageTimeSpent Float   @default(0)
  averageAccuracy Float    @default(0)
  completionRate   Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([challengeId])
  @@map("challenge_analytics")
}

model DailyAnalytics {
  id               String   @id @default(cuid())
  date             DateTime @db.Date
  totalAttempts   Int      @default(0)
  completedAttempts Int    @default(0)
  totalScore      Float    @default(0)
  averageScore    Float    @default(0)
  averageAccuracy Float    @default(0)
  newUsers        Int      @default(0)
  activeUsers     Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([date])
  @@index([date])
  @@map("daily_analytics")
}

// ─── Reports & Abuse Management ─────────────────────────────

enum ReportStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  DISMISSED
}

enum ReportPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ReportType {
  USER_ABUSE
  CHEATING
  SPAM
  INAPPROPRIATE_CONTENT
  CHALLENGE_ISSUE
  QUESTION_ERROR
  OTHER
}

model Report {
  id                String         @id @default(cuid())
  type              ReportType
  reason            String
  description       String?        @db.Text
  status            ReportStatus   @default(OPEN)
  priority          ReportPriority @default(MEDIUM)
  reportedById      String
  reportedBy        User           @relation("ReportSubmitter", fields: [reportedById], references: [id], onDelete: Cascade)
  targetUserId      String?
  targetUser        User?          @relation("ReportTarget", fields: [targetUserId], references: [id], onDelete: SetNull)
  targetChallengeId String?
  targetChallenge   Challenge?     @relation("ReportedChallenge", fields: [targetChallengeId], references: [id], onDelete: SetNull)
  targetQuestionId  String?
  targetQuestion    Question?      @relation("ReportedQuestion", fields: [targetQuestionId], references: [id], onDelete: SetNull)
  reviewedById      String?
  reviewedBy        User?          @relation("ReportReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt        DateTime?
  resolutionNotes   String?        @db.Text
  notes             ReportNote[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([status])
  @@index([priority])
  @@index([type])
  @@index([reportedById])
  @@index([targetUserId])
  @@index([targetChallengeId])
  @@index([targetQuestionId])
  @@index([reviewedById])
  @@index([createdAt])
  @@map("reports")
}

model ReportNote {
  id          String   @id @default(cuid())
  reportId    String
  report      Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  authorId    String
  author      User     @relation("ReportNoteAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  content     String   @db.Text
  isInternal  Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([reportId])
  @@index([authorId])
  @@map("report_notes")
}

// ─── Platform Settings & Feature Controls ────────────────────

model PlatformSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  category    String
  description String?
  isProtected Boolean  @default(false)
  updatedById String?
  updatedBy   User?    @relation("SettingUpdater", fields: [updatedById], references: [id])
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@index([category])
  @@index([key])
  @@map("platform_settings")
}

model SettingAudit {
  id            String   @id @default(cuid())
  settingKey    String
  previousValue Json?
  newValue      Json
  reason        String?  @db.Text
  changedById   String
  changedBy     User     @relation("SettingAuditActor", fields: [changedById], references: [id])
  changedAt     DateTime @default(now())

  @@index([settingKey])
  @@index([changedById])
  @@index([changedAt])
  @@map("setting_audits")
}