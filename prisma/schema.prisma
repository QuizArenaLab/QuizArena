model QuestionUsageStats {
  id         String   @id @default(cuid())
  questionId String   @unique
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  // Tracking limits
  timesServed       Int @default(0)
  timesAttempted    Int @default(0)
  correctAttempts   Int @default(0)
  incorrectAttempts Int @default(0)
  skippedAttempts   Int @default(0)

  // Metrics
  averageTimeSpent Float                @default(0)
  actualDifficulty ChallengeDifficulty?
  successRate      Float                @default(0)

  // Time analytics
  medianTimeSpent Float @default(0)
  fastestTime     Int?
  slowestTime     Int?
  p90Time         Int?

  // Report tracking
  reportCount Int @default(0)

  // Trends (e.g., "UP", "DOWN", "STABLE")
  successRateTrend String @default("STABLE")
  attemptsTrend    String @default("STABLE")
  reportsTrend     String @default("STABLE")

  // Timestamps
  lastAttemptedAt DateTime?
  lastServedAt    DateTime?

  // Versioning & quality
  analyticsVersion Int         @default(1)
  dataQuality      DataQuality @default(INSUFFICIENT)
  lastCalculatedAt DateTime?

  // Processing
  needsProcessing Boolean @default(false)

  updatedAt DateTime @updatedAt

  @@index([needsProcessing])
  @@index([actualDifficulty])
  @@index([successRate])
  @@index([dataQuality])
  @@index([timesAttempted])
  @@map("question_usage_stats")
