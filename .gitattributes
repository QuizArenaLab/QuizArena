# Set default behavior, forcing LF line endings for all text files
* text=auto eol=lf

# Explicitly declare text files you want to always be normalized and converted
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.css text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.html text eol=lf

# Explicitly declare binary files so Git doesn't try to normalize them
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
